{
    "name": "ngx-bot-ssr",
    "version": "2026.4.106",
    "corifeus": {
        "icon": "fas fa-robot",
        "prefix": "ngx-",
        "publish": true,
        "type": "ngx",
        "code": "Crawler",
        "nodejs": "v24.14.1",
        "opencollective": false,
        "reponame": "bot-ssr",
        "build": true
    },
    "description": "🤖 Angular SSR for bots, prebuilt CSR shell for humans. Faster page loads for users, fully prerendered HTML for Googlebot, Bingbot, Yandex, ClaudeBot, GPTBot and link unfurlers.",
    "main": "src/index.js",
    "module": "src/index.mjs",
    "types": "src/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./src/index.d.mts",
                "default": "./src/index.mjs"
            },
            "require": {
                "types": "./src/index.d.ts",
                "default": "./src/index.js"
            },
            "default": "./src/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "src/index.js",
        "src/index.mjs",
        "src/index.d.ts",
        "src/index.d.mts",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "test": "grunt && mocha ./test/mocha/*.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/patrikx3/bot-ssr.git"
    },
    "keywords": [
        "angular",
        "angular-ssr",
        "ssr",
        "csr",
        "bot",
        "bots",
        "crawler",
        "crawlers",
        "googlebot",
        "bingbot",
        "claudebot",
        "gptbot",
        "yandexbot",
        "isbot",
        "user-agent",
        "seo",
        "prerender",
        "express",
        "middleware",
        "ngx"
    ],
    "author": "Patrik Laszlo <alabard@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/patrikx3/bot-ssr/issues"
    },
    "homepage": "https://corifeus.com/bot-ssr",
    "dependencies": {
        "isbot": "^5.1.39"
    },
    "peerDependencies": {
        "express": ">=4.18.0"
    },
    "devDependencies": {
        "corifeus-builder": "^2026.4.157",
        "express": "^5.2.1",
        "mocha": "^11.7.5"
    },
    "engines": {
        "node": ">=12.13.0"
    }
}